{
  "name": "destinyone",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm store:manifest:verify",
    "export:web": "expo export --platform web --output-dir dist",
    "build": "pnpm build:web",
    "build:web": "pnpm export:web",
    "release:check": "pnpm check && pnpm build:web",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset",
    "supabase:test": "supabase test db",
    "supabase:lint": "supabase db lint --level error",
    "supabase:types": "supabase gen types typescript --local",
    "supabase:check": "pnpm supabase:reset && pnpm supabase:test && pnpm supabase:lint",
    "supabase:verify": "node scripts/verify-supabase-deployment.mjs",
    "backend:preflight": "node scripts/preflight-supabase-production.mjs",
    "mobile:build:verify": "node scripts/verify-mobile-build-environment.mjs",
    "mobile:native:verify": "node scripts/verify-native-project.mjs",
    "mobile:pilot:evidence": "node scripts/verify-mobile-pilot-evidence.mjs",
    "store:manifest:verify": "node scripts/verify-store-release-manifest.mjs --mode=draft",
    "store:release:verify": "node scripts/verify-store-release-manifest.mjs --mode=production",
    "eas-build-pre-install": "node scripts/verify-mobile-build-environment.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo-google-fonts/satisfy": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@stripe/stripe-react-native": "0.63.0",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "~55.0.0",
    "expo-audio": "~55.0.15",
    "expo-dev-client": "~55.0.37",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.21",
    "expo-linear-gradient": "~55.0.3",
    "expo-location": "~55.1.11",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.20",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "supabase": "^2.109.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
