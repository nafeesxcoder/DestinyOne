# Public client values from Supabase Project Settings > API.
# Never place a service-role key in an Expo app.
# Use development, staging, or production. Production also requires the real
# backend lock and both Supabase values to be supplied by the release environment.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_REQUIRE_REAL_BACKEND=false
EXPO_PUBLIC_ENABLE_PREVIEW_AUTH_BYPASS=false
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Stripe publishable keys are safe for the app; secret keys must stay server-side.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_PAYMENTS_API_URL=
EXPO_PUBLIC_GIFTS_API_URL=

# Google Places is server-only. Set this in Supabase Edge Function secrets,
# never as EXPO_PUBLIC_GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_API_KEY=

# Server/CI-only Supabase deployment values. Never prefix these with
# EXPO_PUBLIC_ and never bundle them into the app.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BASELINE_APPROVED=false
